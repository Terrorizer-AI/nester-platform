# ── Nester Agent Platform — Environment Configuration ────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run ./setup.sh for an interactive wizard.

# --- LLM Providers (required) ---
OPENAI_API_KEY=your_openai_key
OPENAI_RESEARCH_MODEL=gpt-4o
OPENAI_SYNTHESIS_MODEL=gpt-4o
OPENAI_EMAIL_MODEL=gpt-4o

# --- Local Storage ---
NESTER_DATA_DIR=~/.nester

# --- Mem0 (agent memory) ---
MEM0_LLM_MODEL=gpt-4o-mini
MEM0_EMBEDDING_MODEL=text-embedding-3-small

# --- Langfuse v3 (observability — optional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
NO_PROXY=localhost,127.0.0.1

# --- OAuth2 Providers (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8000

# --- MCP Tool Servers ---
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
# LINKEDIN — no API key needed (browser-based MCP server)
FIRECRAWL_API_KEY=your_firecrawl_key
TAVILY_API_KEY=your_tavily_key
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- Calendly (optional) ---
CALENDLY_API_KEY=
CALENDLY_USER_URI=
CALENDLY_EVENT_TYPE_URI=
CALENDLY_SCHEDULING_URL=

# --- Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Browser (Playwright) ---
PLAYWRIGHT_HEADLESS=true
BROWSER_POOL_SIZE=2
BROWSER_PAGE_TIMEOUT_MS=30000

# --- Cost Budgets ---
DEFAULT_COST_BUDGET_PER_FLOW=0.50
DEFAULT_COST_BUDGET_PER_USER=5.00
COST_ALERT_THRESHOLD=0.8

# --- Platform ---
PLATFORM_ORG_ID=nester
API_SECRET_KEY=change-this-in-production
LOG_LEVEL=INFO
